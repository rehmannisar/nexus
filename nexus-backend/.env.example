# Rename this file to .env before running

PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/nexusDB?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS) - Vercel deployment link
CLIENT_URL=https://nexus-iota-five.vercel.app
